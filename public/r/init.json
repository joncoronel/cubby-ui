  "css": {
    "@keyframes skeleton": {
      "to": {
        "background-position-x": "-200%"
      }
    },
    "@keyframes otp-field-shake-a": {
      "0%,\r\n    100%": {
        "transform": "translateX(0)"
      },
      "25%": {
        "transform": "translateX(-4px)"
      },
      "75%": {
        "transform": "translateX(4px)"
      }
    },
    "@keyframes otp-field-shake-b": {
      "0%,\r\n    100%": {
        "transform": "translateX(0)"
      },
      "25%": {
        "transform": "translateX(-4px)"
      },
      "75%": {
        "transform": "translateX(4px)"
      }
    },
    "@layer base": {
      "body": {
        "position": "relative"
      },
      ".root": {
        "isolation": "isolate"
      }
    }
  },
